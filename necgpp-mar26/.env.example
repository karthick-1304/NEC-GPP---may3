# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10
DB_QUEUE_TIMEOUT_MS=8000
DB_QUERY_EXECUTION_TIMEOUT_S=10
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_string_here_xxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_SECONDS=604800

# ─── Email (Gmail App Password) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@nec.edu.in
SMTP_PASS=your_gmail_app_password
SMTP_FROM=GATE Portal <your_email@nec.edu.in>

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=600
OTP_COOLDOWN_SECONDS=120
OTP_DIGITS=6

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── App constants ────────────────────────────────────────────────────────────
MAX_TEST_ATTEMPTS=3
BCRYPT_SALT_ROUNDS=12
NEW_ACCOUNT_DEFAULT_PASSWORD=systemAccessPass

# ─── ImgBB ───────────────────────────────────────────────────────────────
IMGBB_API_KEY=your_imgbb_api_key_here
